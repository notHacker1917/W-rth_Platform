# Server
NODE_ENV=production
PORT=3000
API_PREFIX=/api

# Auth — CHANGE JWT_SECRET in production (use a long random string)
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Default password applied to every seeded demo account so the existing
# mock users (u1, u2, ...) can log in. Change or remove for production.
SEED_PASSWORD=wurth1234

# CORS — comma-separated allowed origins, or * for all (dev only)
# e.g. https://app.wurth-platform.com,https://staging.wurth-platform.com
CORS_ORIGINS=*

# Where seed.json lives and db.json is written
DATA_DIR=./data

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
